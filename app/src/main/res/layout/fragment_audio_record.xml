<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".fragments.AudioRecordFragment">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp"
            android:gravity="center">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="40dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="12dp">

                    <View
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_icon_circle_green" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_mic"
                        app:tint="@color/green_600" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Voice Recording"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:letterSpacing="-0.02" />

                <ImageButton
                    android:id="@+id/btnClose"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_close"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Close"
                    app:tint="@color/text_secondary" />
            </LinearLayout>

            <!-- Recording Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/divider_color"
                app:cardBackgroundColor="@color/surface"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="32dp"
                    android:gravity="center">

                    <!-- Status Text -->
                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ready to record"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_500"
                        android:layout_marginBottom="28dp" />

                    <!-- Recording Indicator -->
                    <View
                        android:id="@+id/recordingIndicator"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:background="@drawable/recording_indicator_bg"
                        android:visibility="gone"
                        android:layout_marginBottom="24dp" />

                    <!-- Timer -->
                    <TextView
                        android:id="@+id/tvTimer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00"
                        android:textSize="56sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="32dp" />

                    <!-- Waveform -->
                    <View
                        android:id="@+id/waveformView"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:background="@drawable/waveform_bg"
                        android:layout_marginBottom="28dp" />

                    <!-- Recording Control -->
                    <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:id="@+id/btnStopRecording"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_stop"
                        app:fabSize="normal"
                        app:backgroundTint="@color/secondary_500"
                        app:tint="@android:color/white"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.FAB"
                        android:enabled="false" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Playback Controls -->
            <LinearLayout
                android:id="@+id/playbackControls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="24dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/divider_color"
                    app:cardBackgroundColor="@color/surface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Preview Recording"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="16dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center">

                            <ImageButton
                                android:id="@+id/btnPlayPause"
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:src="@drawable/ic_play"
                                android:background="@drawable/circle_button_bg"
                                android:contentDescription="Play/Pause"
                                android:padding="16dp"
                                android:enabled="false"
                                app:tint="@color/primary_500" />

                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/btnDiscardRecording"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Discard"
                    android:textColor="@color/red_500"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:background="@drawable/button_outline_red"
                    android:textAllCaps="false"
                    android:drawableStart="@drawable/ic_delete"
                    android:drawablePadding="8dp" />

                <Button
                    android:id="@+id/btnSaveRecording"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Save"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:background="@drawable/button_background_green"
                    android:textAllCaps="false"
                    android:drawableStart="@drawable/ic_save"
                    android:drawablePadding="8dp"
                    android:enabled="false" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
