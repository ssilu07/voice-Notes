<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipToPadding="false"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                app:tint="@color/text_primary" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/btnReminder"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_reminder"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Set reminder"
                android:layout_marginEnd="4dp"
                app:tint="@color/text_secondary" />

            <ImageButton
                android:id="@+id/btnEdit"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_edit"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Edit"
                android:layout_marginEnd="4dp"
                app:tint="@color/primary_500" />

            <ImageButton
                android:id="@+id/btnDelete"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Delete"
                app:tint="@color/red_400" />

        </LinearLayout>

        <!-- Note Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/divider_color"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Title -->
                <TextView
                    android:id="@+id/tvNoteTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:letterSpacing="-0.02"
                    android:layout_marginBottom="12dp"
                    tools:text="Sample Note Title" />

                <!-- Timestamp + Reminder indicator -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:id="@+id/tvTimestamp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="13sp"
                        android:textColor="@color/text_hint"
                        android:drawableStart="@drawable/ic_time"
                        android:drawablePadding="6dp"
                        tools:text="Dec 15, 2024 - 14:30" />

                    <TextView
                        android:id="@+id/tvReminderInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/primary_500"
                        android:textStyle="bold"
                        android:background="@drawable/bg_chip_badge"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:drawableStart="@drawable/ic_reminder"
                        android:drawablePadding="4dp"
                        android:visibility="gone"
                        tools:text="Mar 20" />

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider_color"
                    android:layout_marginBottom="12dp" />

                <!-- Rich Text Formatting Toolbar -->
                <HorizontalScrollView
                    android:id="@+id/formattingToolbar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:scrollbars="none"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/status_bg"
                        android:paddingHorizontal="8dp">

                        <ImageButton
                            android:id="@+id/btnBold"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_format_bold"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Bold"
                            android:layout_marginEnd="4dp"
                            app:tint="@color/text_primary" />

                        <ImageButton
                            android:id="@+id/btnItalic"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_format_italic"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Italic"
                            android:layout_marginEnd="4dp"
                            app:tint="@color/text_primary" />

                        <ImageButton
                            android:id="@+id/btnUnderline"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_format_underline"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Underline"
                            android:layout_marginEnd="4dp"
                            app:tint="@color/text_primary" />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="24dp"
                            android:background="@color/divider_color"
                            android:layout_marginHorizontal="8dp" />

                        <ImageButton
                            android:id="@+id/btnBulletList"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_format_list"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Bullet list"
                            app:tint="@color/text_primary" />

                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Content -->
                <EditText
                    android:id="@+id/etNoteContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="250dp"
                    android:gravity="top|start"
                    android:inputType="textMultiLine|textCapSentences"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:lineSpacingMultiplier="1.5"
                    android:background="@android:color/transparent"
                    android:enabled="false"
                    android:focusable="false"
                    tools:text="This is the content of the note..." />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
